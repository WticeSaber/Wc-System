# Copy this file to .env and fill in your values.
# The .env file is loaded by docker-compose automatically.

# --- Required for DeepSeek semantic layer (Phase 3) ---
# Leave blank to run without AI momentum modifiers.
DEEPSEEK_API_KEY=

# --- Data source mode ---
# "live" = fetch from GitHub (requires internet)
# "mock" = use local files in mock/ (offline development)
DATA_SOURCE=live

# --- HTTP server configuration ---
PORT=8080

# --- Elo linear regression slope (optional tuning knob) ---
# Valid range: 0.0009 to 0.0014 (default: 0.0011)
# ELO_SLOPE=0.0011

# --- FM CSV file path (optional Football Manager export) ---
# FM_CSV_PATH=./data/fm_export.csv

# --- Cache refresh interval in hours (default: 24) ---
# DATA_REFRESH_INTERVAL=24
